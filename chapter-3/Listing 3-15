# Listing 3-15 update using bulk_update method

books = Book.objects.filter(author__name="J.K. Rowling")
for b in books:
    b.price = (b.price or 0) + 50
Book.objects.bulk_update(books, ['price'])

# Equivalent SQL

UPDATE book
SET price = CASE
    WHEN id = 1 THEN 550
    WHEN id = 2 THEN 650
END
WHERE id IN (1, 2);