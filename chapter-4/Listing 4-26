# Listing 4-26 Using get_or_create with defaults

author = Author.objects.get(name="J.K. Rowling")
book, created = Book.objects.get_or_create(
    title="Harry Potter",
    defaults={
        "author": author,
        "price": 500.00
    }
)
print(book)
print(created)

# Equivalent SQL (when record does not exist)

# First Query

SELECT book.id, book.title, book.author_id, book.price,
book.number_of_pages, book.published_date,
book.created_at
FROM book
WHERE book.title = 'Harry Potter'
LIMIT 1;
 
# Second Query

INSERT INTO book (title, author_id, price) VALUES ('Harry Potter', 1, 500.00);