# Listing 4-20 Using extra with select
 
books = Book.objects.extra(
    select={"title_length": "LENGTH(title)"}
)
for book in books:
    print(book.title, book.title_length)

# Equivalent SQL

SELECT book.id, book.title, book.author_id, book.price,
book.number_of_pages, book.published_date,
book.created_at,
LENGTH(title) AS title_length
FROM book;