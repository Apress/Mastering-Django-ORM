# Listing 4-5 Using distinct with ManyToMany relationship

books = Book.objects.filter(genres__name__in=["Fantasy", "Drama"])

# Equivalent SQL

SELECT book.id, book.title, book.author_id, book.price,
book.number_of_pages, book.published_date,
book.created_at
FROM book
INNER JOIN book_genres
ON book.id = book_genres.book_id
INNER JOIN genre
ON book_genres.genre_id = genre.id
WHERE genre.name IN ('Fantasy', 'Drama');