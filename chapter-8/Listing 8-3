# Listing 8-3 Async Transaction

from django.db import transaction
from asgiref.sync import sync_to_async
 
@sync_to_async
def create_books():
    with transaction.atomic():
        Book.objects.create(title="Async Django")
        Book.objects.create(title="Advanced Async")
 
async def create_book(request):
    await create_books()
 
